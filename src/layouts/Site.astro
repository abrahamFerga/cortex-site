---
// The brand-page frame: design tokens, fluid type, sticky glass nav, rich footer.
// Docs pages use Starlight's layout; this stays dependency-free (system font stack,
// pure CSS — no framework, no JS beyond none at all).
interface Props {
	title: string;
	description?: string;
}
const {
	title,
	description = 'AI vertical products with a security spine: permission-checked, approval-gated, audited.',
} = Astro.props;
const url = Astro.url?.pathname ?? '/';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="theme-color" content="#0c0a1d" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<style is:global>
			/* ── Design tokens ─────────────────────────────────────────────── */
			:root {
				--ink: #0f172a;
				--ink-2: #334155;
				--muted: #64748b;
				--faint: #94a3b8;
				--line: #e2e8f0;
				--surface: #f8fafc;
				--bg: #ffffff;
				--brand: #4f46e5;
				--brand-2: #7c3aed;
				--brand-dark: #4338ca;
				--brand-ink: #eef2ff;
				--night: #0c0a1d;
				--night-2: #171331;
				--ok: #059669;
				--grad: linear-gradient(135deg, var(--brand) 0%, var(--brand-2) 100%);
				--radius: 16px;
				--shadow-1: 0 1px 2px rgb(15 23 42 / 0.06), 0 8px 24px rgb(15 23 42 / 0.06);
				--shadow-2: 0 2px 6px rgb(79 70 229 / 0.12), 0 16px 48px rgb(79 70 229 / 0.18);
				--font: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Inter, sans-serif;
				--mono: ui-monospace, 'Cascadia Code', 'Segoe UI Mono', Menlo, monospace;
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			html { scroll-behavior: smooth; }
			body {
				font-family: var(--font);
				color: var(--ink);
				background: var(--bg);
				line-height: 1.65;
				-webkit-font-smoothing: antialiased;
				text-rendering: optimizeLegibility;
			}
			img, svg { display: block; max-width: 100%; }
			a { color: var(--brand); }

			/* ── Fluid type scale ──────────────────────────────────────────── */
			h1 { font-size: clamp(2.1rem, 1.2rem + 3.6vw, 3.6rem); line-height: 1.08; letter-spacing: -0.035em; font-weight: 800; }
			h2 { font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.2rem); line-height: 1.15; letter-spacing: -0.025em; font-weight: 750; }
			h3 { font-size: 1.08rem; font-weight: 650; letter-spacing: -0.01em; }
			.lead { font-size: clamp(1.05rem, 0.95rem + 0.5vw, 1.25rem); color: var(--muted); }
			.kicker {
				display: inline-block; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em;
				text-transform: uppercase; color: var(--brand); margin-bottom: 0.9rem;
			}

			/* ── Layout primitives ─────────────────────────────────────────── */
			.wrap { max-width: 72rem; margin: 0 auto; padding-inline: clamp(1.25rem, 4vw, 2.5rem); }
			section.band { padding-block: clamp(3.5rem, 8vw, 6.5rem); }
			.grid { display: grid; gap: 1.25rem; }
			.cols-2 { grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr)); }
			.cols-3 { grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr)); }
			.cols-4 { grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr)); }

			/* ── Buttons ───────────────────────────────────────────────────── */
			.btn {
				display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
				background: var(--grad); color: white; padding: 0.8rem 1.6rem;
				border-radius: 999px; text-decoration: none; font-weight: 650; font-size: 0.98rem;
				box-shadow: var(--shadow-2); transition: transform 0.15s ease, box-shadow 0.15s ease;
				border: 0; cursor: pointer;
			}
			.btn:hover { transform: translateY(-2px); box-shadow: 0 4px 10px rgb(79 70 229 / 0.2), 0 22px 56px rgb(79 70 229 / 0.26); }
			.btn.ghost {
				background: transparent; color: var(--ink); border: 1.5px solid var(--line);
				box-shadow: none;
			}
			.btn.ghost:hover { border-color: var(--brand); color: var(--brand); transform: translateY(-2px); }
			.btn.on-dark.ghost { color: white; border-color: rgb(255 255 255 / 0.28); }
			.btn.on-dark.ghost:hover { border-color: white; color: white; }

			/* ── Cards ─────────────────────────────────────────────────────── */
			.card {
				background: var(--bg); border: 1px solid var(--line); border-radius: var(--radius);
				padding: 1.6rem; box-shadow: var(--shadow-1);
				transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
			}
			.card:hover { transform: translateY(-3px); box-shadow: var(--shadow-2); border-color: #c7d2fe; }
			.card h3 { margin-bottom: 0.45rem; }
			.card p { color: var(--muted); font-size: 0.95rem; }
			.icon {
				width: 2.4rem; height: 2.4rem; border-radius: 10px; display: grid; place-items: center;
				background: var(--brand-ink); color: var(--brand); font-size: 1.15rem; margin-bottom: 0.9rem;
			}

			/* ── Nav ───────────────────────────────────────────────────────── */
			header.site {
				position: sticky; top: 0; z-index: 50;
				background: rgb(255 255 255 / 0.82); backdrop-filter: blur(12px);
				border-bottom: 1px solid rgb(226 232 240 / 0.7);
			}
			header.site .inner {
				max-width: 72rem; margin: 0 auto; padding: 0.8rem clamp(1.25rem, 4vw, 2.5rem);
				display: flex; align-items: center; gap: 2rem;
			}
			.logo { display: flex; align-items: center; gap: 0.55rem; font-weight: 800; font-size: 1.12rem; letter-spacing: -0.02em; color: var(--ink); text-decoration: none; }
			.logo .mark { width: 1.7rem; height: 1.7rem; }
			header.site nav { display: flex; gap: 1.5rem; margin-left: auto; align-items: center; }
			header.site nav a { color: var(--ink-2); text-decoration: none; font-size: 0.94rem; font-weight: 550; }
			header.site nav a:hover { color: var(--brand); }
			header.site nav a.cta {
				background: var(--grad); color: white; padding: 0.5rem 1.1rem; border-radius: 999px;
				font-weight: 650;
			}
			@media (max-width: 640px) { header.site nav a:not(.cta) { display: none; } }

			/* ── Dark band ─────────────────────────────────────────────────── */
			.dark-band {
				background: radial-gradient(80rem 40rem at 70% -20%, #2a1d5e 0%, var(--night) 55%);
				color: #e2e8f0;
			}
			.dark-band h2, .dark-band h3 { color: white; }
			.dark-band .card {
				background: rgb(255 255 255 / 0.04); border-color: rgb(255 255 255 / 0.1);
				box-shadow: none;
			}
			.dark-band .card:hover { border-color: rgb(255 255 255 / 0.25); box-shadow: none; }
			.dark-band .card p { color: #94a3b8; }
			.dark-band .icon { background: rgb(124 58 237 / 0.2); color: #c4b5fd; }

			/* ── Footer ────────────────────────────────────────────────────── */
			footer.site { background: var(--night); color: #94a3b8; padding: 3.5rem 0 2.5rem; font-size: 0.92rem; }
			footer.site .cols { display: grid; gap: 2rem; grid-template-columns: 2fr repeat(3, 1fr); }
			@media (max-width: 720px) { footer.site .cols { grid-template-columns: 1fr 1fr; } }
			footer.site h4 { color: white; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.8rem; }
			footer.site a { color: #94a3b8; text-decoration: none; display: block; padding-block: 0.18rem; }
			footer.site a:hover { color: white; }
			footer.site .legal { border-top: 1px solid rgb(255 255 255 / 0.08); margin-top: 2.5rem; padding-top: 1.5rem; font-size: 0.82rem; color: #64748b; }

			/* ── Motion (respects reduced-motion) ──────────────────────────── */
			@media (prefers-reduced-motion: no-preference) {
				.rise { animation: rise 0.7s cubic-bezier(0.2, 0.7, 0.3, 1) both; }
				.rise-2 { animation: rise 0.7s 0.12s cubic-bezier(0.2, 0.7, 0.3, 1) both; }
				.rise-3 { animation: rise 0.7s 0.24s cubic-bezier(0.2, 0.7, 0.3, 1) both; }
				@keyframes rise { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }
			}
		</style>
	</head>
	<body>
		<header class="site">
			<div class="inner">
				<a href="/" class="logo">
					<svg class="mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
						<defs><linearGradient id="lg" x1="0" y1="0" x2="32" y2="32"><stop stop-color="#4f46e5"/><stop offset="1" stop-color="#7c3aed"/></linearGradient></defs>
						<path d="M16 2l12 7v14l-12 7-12-7V9l12-7z" stroke="url(#lg)" stroke-width="2.6" stroke-linejoin="round"/>
						<circle cx="16" cy="16" r="4.2" fill="url(#lg)"/>
					</svg>
					Cortex
				</a>
				<nav aria-label="Primary">
					<a href="/products/casewell" aria-current={url.startsWith('/products') ? 'page' : undefined}>Products</a>
					<a href="/pricing" aria-current={url.startsWith('/pricing') ? 'page' : undefined}>Pricing</a>
					<a href="/docs/casewell/getting-started">Docs</a>
					<a class="cta" href="/pricing">Get started</a>
				</nav>
			</div>
		</header>

		<slot />

		<footer class="site">
			<div class="wrap">
				<div class="cols">
					<div>
						<a href="/" class="logo" style="color: white; margin-bottom: 0.8rem;">
							<svg class="mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
								<path d="M16 2l12 7v14l-12 7-12-7V9l12-7z" stroke="#7c8cf8" stroke-width="2.6" stroke-linejoin="round"/>
								<circle cx="16" cy="16" r="4.2" fill="#7c8cf8"/>
							</svg>
							Cortex
						</a>
						<p style="max-width: 20rem;">
							AI vertical products, each its own system — all on one platform with a security
							spine you can audit.
						</p>
					</div>
					<div>
						<h4>Product</h4>
						<a href="/products/casewell">Casewell</a>
						<a href="/pricing">Pricing</a>
						<a href="/docs/casewell/getting-started">Documentation</a>
					</div>
					<div>
						<h4>Trust</h4>
						<a href="/docs/casewell/security">Security model</a>
						<a href="/docs/casewell/plans">Billing &amp; data retention</a>
					</div>
					<div>
						<h4>Company</h4>
						<a href="https://github.com/abrahamFerga/Cortex">GitHub</a>
					</div>
				</div>
				<p class="legal">
					© {new Date().getFullYear()} Cortex. AI output is a starting point for professional
					review — never legal, financial, or medical advice.
				</p>
			</div>
		</footer>
	</body>
</html>
