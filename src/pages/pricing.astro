---
import Site from '../layouts/Site.astro';
import pricing from '../data/pricing.json';
// One JSON drives every pricing surface; checkout buttons deep-link to Stripe Checkout once
// each tier's stripePriceId is set — the webhook then provisions the workspace automatically.
const products = pricing.products;
---

<Site title="Pricing — Cortex" description="Solo, Team, or your own dedicated cloud. Live the moment you subscribe.">
	<section class="dark-band" style="padding-block: clamp(3rem, 6vw, 4.5rem); text-align: center;">
		<div class="wrap rise">
			<span class="kicker" style="color: #a5b4fc;">Pricing</span>
			<h1 style="color: white;">Every plan provisions itself.</h1>
			<p class="lead" style="color: #a5b0c8; margin-top: 1rem; max-width: 34rem; margin-inline: auto;">
				Pay, and your workspace exists — modules licensed, seats set, budgets applied.
				Change or cancel any time from the customer portal.
			</p>
		</div>
	</section>

	{products.map((product) => (
		<section class="band">
			<div class="wrap">
				<h2>{product.name}</h2>
				<p class="lead" style="margin-top: 0.5rem; max-width: 40rem;">{product.tagline}</p>

				<div class="grid cols-3" style="margin-top: 2.5rem; align-items: stretch;">
					{product.tiers.map((tier) => (
						<div
							class="card"
							style={`display: flex; flex-direction: column; ${tier.highlighted ? 'border-color: var(--brand); box-shadow: var(--shadow-2); position: relative;' : ''}`}
						>
							{tier.highlighted && (
								<span style="position: absolute; top: -0.8rem; left: 50%; transform: translateX(-50%); background: var(--grad); color: white; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border-radius: 999px; padding: 0.25rem 0.9rem;">
									Most popular
								</span>
							)}
							<h3>{tier.name}</h3>
							<p style="margin-top: 0.8rem;">
								<span style="font-size: 2.3rem; font-weight: 800; letter-spacing: -0.03em; color: var(--ink);">{tier.price}</span>
								<span style="color: var(--muted); font-size: 0.9rem;"> {tier.per}</span>
							</p>
							<ul style="margin: 1.4rem 0 1.8rem; padding: 0; list-style: none; flex: 1; display: grid; gap: 0.55rem;">
								{tier.features.map((f) => (
									<li style="display: flex; gap: 0.55rem; font-size: 0.94rem; color: var(--ink-2);">
										<span style="color: var(--ok); font-weight: 800;">✓</span>
										{f}
									</li>
								))}
							</ul>
							<a class={tier.highlighted ? 'btn' : 'btn ghost'} href="/docs/the-lawyer/plans" style="text-align: center; width: 100%;">
								{tier.cta}
							</a>
						</div>
					))}
				</div>

				<div class="grid cols-3" style="margin-top: 2.5rem;">
					<div style="border-left: 3px solid var(--brand); padding-left: 1rem;">
						<h3 style="font-size: 0.95rem;">Seats that flex</h3>
						<p style="color: var(--muted); font-size: 0.9rem;">Add or remove seats in the portal; the workspace limit follows within a minute. Deactivating a member frees their seat instantly.</p>
					</div>
					<div style="border-left: 3px solid var(--brand); padding-left: 1rem;">
						<h3 style="font-size: 0.95rem;">AI included — or yours</h3>
						<p style="color: var(--muted); font-size: 0.9rem;">Metered AI with a hard cap (alerts at 80%, stops at 100%) — or bring your own provider key and pay them directly.</p>
					</div>
					<div style="border-left: 3px solid var(--brand); padding-left: 1rem;">
						<h3 style="font-size: 0.95rem;">Fair exit</h3>
						<p style="color: var(--muted); font-size: 0.9rem;">Failed payments suspend, never delete. Cancellation keeps your data 30 days for export. No lock-in theatrics.</p>
					</div>
				</div>

				<p style="color: var(--faint); font-size: 0.85rem; margin-top: 2rem;">
					Prices exclude tax where applicable. Dedicated environments carry an infrastructure fee
					based on region and size — final quote before you pay, no surprises after.
				</p>
			</div>
		</section>
	))}

	<section class="band dark-band">
		<div class="wrap" style="text-align: center;">
			<h2>Not sure which plan?</h2>
			<p class="lead" style="color: #a5b0c8; margin-top: 0.8rem;">
				Start Solo — upgrading to Team is a seat change, and your data moves nowhere.
			</p>
			<a class="btn" href="/docs/the-lawyer/plans" style="margin-top: 1.8rem;">How plans work, in detail</a>
		</div>
	</section>
</Site>
